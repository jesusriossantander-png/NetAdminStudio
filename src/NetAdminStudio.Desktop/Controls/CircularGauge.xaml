<UserControl x:Class="NetAdminStudio.Desktop.Controls.CircularGauge"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Width="98" Height="98">
    <Grid>
        <Ellipse Width="98" Height="98" Stroke="#22314F" StrokeThickness="9"/>
        <Path x:Name="ArcPath" StrokeThickness="9"
              StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
            <TextBlock x:Name="ValueText" Text="0%" FontSize="20" FontWeight="Bold"
                       HorizontalAlignment="Center" Foreground="#F3F4F6"/>
            <TextBlock x:Name="LabelText" Text="" FontSize="10"
                       HorizontalAlignment="Center" Foreground="#94A3B8"/>
        </StackPanel>
    </Grid>
</UserControl>
