<UserControl x:Class="NetAdminStudio.Desktop.Controls.CircularGauge"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <Ellipse x:Name="Ring" Stroke="#22314F"/>
        <Path x:Name="ArcPath" StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
            <TextBlock x:Name="ValueText" Text="0%" FontWeight="Bold"
                       HorizontalAlignment="Center" Foreground="#F3F4F6"/>
            <TextBlock x:Name="LabelText" Text=""
                       HorizontalAlignment="Center" Foreground="#94A3B8"/>
        </StackPanel>
    </Grid>
</UserControl>
