<Window x:Class="NetAdminStudio.Desktop.Controls.DetailWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Detalle"
        Width="560" SizeToContent="Height" MaxHeight="720"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False">
    <Border Background="{StaticResource BackgroundBrush}" Padding="0">
        <DockPanel>
            <Border DockPanel.Dock="Top" Background="{StaticResource SidebarBrush}" Padding="20,16">
                <StackPanel>
                    <TextBlock x:Name="TitleText" Text="Detalle" FontSize="20" FontWeight="Bold"/>
                    <TextBlock x:Name="SubtitleText" Text="" Foreground="{StaticResource MutedBrush}"
                               FontSize="12" Margin="0,2,0,0"/>
                </StackPanel>
            </Border>

            <Border DockPanel.Dock="Bottom" Padding="20,12" Background="{StaticResource SidebarBrush}">
                <Button Content="Cerrar" Style="{StaticResource PrimaryButton}"
                        HorizontalAlignment="Right" Click="Close_Click"/>
            </Border>

            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <ItemsControl x:Name="FieldsList" Margin="16">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="{StaticResource SurfaceBrush}" CornerRadius="8"
                                    Padding="14,10" Margin="0,0,0,8">
                                <StackPanel>
                                    <TextBlock Text="{Binding Label}" Foreground="{StaticResource MutedBrush}"
                                               FontSize="11"/>
                                    <TextBlock Text="{Binding Value}" FontSize="14" TextWrapping="Wrap"
                                               Margin="0,2,0,0"/>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </DockPanel>
    </Border>
</Window>
