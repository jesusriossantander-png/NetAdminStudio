<UserControl x:Class="NetAdminStudio.Desktop.Views.AuditoriaView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:b="clr-namespace:NetAdminStudio.Desktop.Behaviors">
    <StackPanel Margin="18">
        <DockPanel Margin="6,4,6,0" LastChildFill="False">
            <StackPanel DockPanel.Dock="Left">
                <TextBlock Text="Auditoría" FontSize="26" FontWeight="SemiBold"/>
                <TextBlock Text="Historial de acciones realizadas en el sistema"
                           Foreground="{StaticResource MutedBrush}"/>
            </StackPanel>
            <Button DockPanel.Dock="Right" Content="↻  Actualizar"
                    Command="{Binding RefreshCommand}" VerticalAlignment="Center"/>
        </DockPanel>

        <Border Style="{StaticResource Card}">
            <StackPanel>
                <DockPanel Margin="0,0,0,10">
                    <TextBlock Text="Registro de auditoría" FontSize="16"
                               FontWeight="SemiBold" VerticalAlignment="Center"/>
                    <TextBlock DockPanel.Dock="Right" HorizontalAlignment="Right"
                               Foreground="{StaticResource MutedBrush}" VerticalAlignment="Center">
                        <Run Text="{Binding Audit.Count, Mode=OneWay}"/><Run Text=" eventos"/>
                    </TextBlock>
                </DockPanel>

                <TextBlock Text="Todavía no hay eventos registrados. Las acciones (escaneos, alertas) se registran automáticamente."
                           Foreground="{StaticResource MutedBrush}" Margin="2,6" TextWrapping="Wrap"
                           Visibility="{Binding Audit.Count, Converter={StaticResource ZeroToVisibility}}"/>

                <DataGrid ItemsSource="{Binding Audit}"
                          AutoGenerateColumns="False" IsReadOnly="True"
                          b:RowDetail.Enabled="True" Height="560">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Fecha y hora" Binding="{Binding AtText}" Width="180"/>
                        <DataGridTextColumn Header="Acción" Binding="{Binding Action}" Width="220"/>
                        <DataGridTextColumn Header="Detalle" Binding="{Binding Detail}" Width="*"/>
                    </DataGrid.Columns>
                </DataGrid>
            </StackPanel>
        </Border>
    </StackPanel>
</UserControl>
