<UserControl x:Class="NetAdminStudio.Desktop.Views.GruposView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <StackPanel Margin="18">
        <DockPanel Margin="6,4,6,0">
            <StackPanel DockPanel.Dock="Left">
                <TextBlock Text="Grupos" FontSize="26" FontWeight="SemiBold"/>
                <TextBlock Text="Grupos locales del equipo"
                           Foreground="{StaticResource MutedBrush}"/>
            </StackPanel>
            <Button DockPanel.Dock="Right" Content="↻  Actualizar"
                    Command="{Binding RefreshCommand}" VerticalAlignment="Center"/>
        </DockPanel>

        <Border Style="{StaticResource Card}">
            <StackPanel>
                <DockPanel Margin="0,0,0,10">
                    <TextBlock Text="Grupos locales" FontSize="16" FontWeight="SemiBold" VerticalAlignment="Center"/>
                    <TextBlock DockPanel.Dock="Right" HorizontalAlignment="Right"
                               Foreground="{StaticResource MutedBrush}" VerticalAlignment="Center">
                        <Run Text="{Binding Groups.Count, Mode=OneWay}"/><Run Text=" grupos"/>
                    </TextBlock>
                </DockPanel>
                <DataGrid ItemsSource="{Binding Groups}"
                          AutoGenerateColumns="False" IsReadOnly="True"
                          Height="560">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Grupo" Binding="{Binding Name}" Width="240"/>
                        <DataGridTextColumn Header="Descripción" Binding="{Binding Description}" Width="*"/>
                    </DataGrid.Columns>
                </DataGrid>
            </StackPanel>
        </Border>
    </StackPanel>
</UserControl>
