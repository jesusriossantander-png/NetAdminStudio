<UserControl x:Class="NetAdminStudio.Desktop.Views.CarpetasView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:b="clr-namespace:NetAdminStudio.Desktop.Behaviors">
    <StackPanel Margin="18">
        <DockPanel Margin="6,4,6,0" LastChildFill="False">
            <StackPanel DockPanel.Dock="Left">
                <TextBlock Text="Carpetas Compartidas" FontSize="26" FontWeight="SemiBold"/>
                <TextBlock Text="Recursos compartidos (SMB) del equipo"
                           Foreground="{StaticResource MutedBrush}"/>
            </StackPanel>
            <Button DockPanel.Dock="Right" Content="↻  Actualizar"
                    Command="{Binding RefreshCommand}" VerticalAlignment="Center"/>
        </DockPanel>

        <Border Style="{StaticResource Card}">
            <StackPanel>
                <DockPanel Margin="0,0,0,10">
                    <TextBlock Text="Recursos compartidos" FontSize="16" FontWeight="SemiBold" VerticalAlignment="Center"/>
                    <TextBlock DockPanel.Dock="Right" HorizontalAlignment="Right"
                               Foreground="{StaticResource MutedBrush}" VerticalAlignment="Center">
                        <Run Text="{Binding Shares.Count, Mode=OneWay}"/><Run Text=" recursos"/>
                    </TextBlock>
                </DockPanel>
                <DataGrid ItemsSource="{Binding Shares}"
                          AutoGenerateColumns="False" IsReadOnly="True"
                          b:RowDetail.Enabled="True" Height="560">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Nombre" Binding="{Binding Name}" Width="180"/>
                        <DataGridTextColumn Header="Ruta" Binding="{Binding Path}" Width="280"/>
                        <DataGridTextColumn Header="Tipo" Binding="{Binding ShareType}" Width="200"/>
                        <DataGridTextColumn Header="Descripción" Binding="{Binding Description}" Width="*"/>
                    </DataGrid.Columns>
                </DataGrid>
            </StackPanel>
        </Border>
    </StackPanel>
</UserControl>
