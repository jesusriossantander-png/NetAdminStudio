<UserControl x:Class="NetAdminStudio.Desktop.Views.EquiposView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:NetAdminStudio.Desktop.Controls">
    <StackPanel Margin="18">
        <DockPanel Margin="6,4,6,0">
            <StackPanel DockPanel.Dock="Left">
                <TextBlock Text="Equipos" FontSize="26" FontWeight="SemiBold"/>
                <TextBlock Text="Detalle del equipo local y computadoras descubiertas"
                           Foreground="{StaticResource MutedBrush}"/>
            </StackPanel>
            <Button DockPanel.Dock="Right" Style="{StaticResource PrimaryButton}"
                    Content="↻  Actualizar" Command="{Binding RefreshCommand}"
                    VerticalAlignment="Center"/>
        </DockPanel>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="420"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Detalle del equipo local -->
            <Border Grid.Column="0" Style="{StaticResource Card}">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <TextBlock Text="🖥️" FontSize="24" VerticalAlignment="Center"/>
                        <StackPanel Margin="10,0,0,0">
                            <TextBlock Text="{Binding LocalSystem.MachineName}"
                                       FontSize="18" FontWeight="Bold"/>
                            <TextBlock Text="{Binding LocalSystem.OperatingSystem}"
                                       Foreground="{StaticResource MutedBrush}" FontSize="12"/>
                        </StackPanel>
                    </StackPanel>

                    <TextBlock Text="{Binding LocalSystem.CpuText}"
                               Foreground="{StaticResource MutedBrush}" FontSize="11"
                               TextWrapping="Wrap" Margin="0,0,0,10"/>

                    <UniformGrid Columns="3">
                        <controls:CircularGauge Label="CPU" Diameter="110"
                            Accent="{StaticResource AccentBrush}"
                            Percent="{Binding LocalSystem.CpuUsagePercent, Mode=OneWay, FallbackValue=0, TargetNullValue=0}"/>
                        <controls:CircularGauge Label="Memoria" Diameter="110"
                            Accent="{StaticResource PurpleBrush}"
                            Percent="{Binding LocalSystem.MemoryUsagePercent, Mode=OneWay, FallbackValue=0}"/>
                        <controls:CircularGauge Label="Disco C:" Diameter="110"
                            Accent="{StaticResource OrangeBrush}"
                            Percent="{Binding LocalSystem.Disks[0].UsagePercent, Mode=OneWay, FallbackValue=0}"/>
                    </UniformGrid>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,6,0,10">
                        <TextBlock Text="{Binding LocalSystem.MemoryText}"
                                   Foreground="{StaticResource MutedBrush}" FontSize="11"/>
                        <TextBlock Text="  ·  " Foreground="{StaticResource MutedBrush}" FontSize="11"/>
                        <TextBlock Text="{Binding LocalSystem.ServicesText}"
                                   Foreground="{StaticResource MutedBrush}" FontSize="11"/>
                    </StackPanel>

                    <TextBlock Text="Discos" FontWeight="SemiBold" FontSize="13" Margin="0,4,0,6"/>
                    <ItemsControl ItemsSource="{Binding LocalSystem.Disks}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="{StaticResource SurfaceAltBrush}"
                                        CornerRadius="8" Padding="10,8" Margin="0,0,0,6">
                                    <StackPanel>
                                        <DockPanel>
                                            <TextBlock Text="{Binding Drive}" DockPanel.Dock="Left" FontWeight="SemiBold"/>
                                            <TextBlock DockPanel.Dock="Right" HorizontalAlignment="Right"
                                                       Foreground="{StaticResource MutedBrush}" FontSize="11">
                                                <Run Text="{Binding UsagePercent, Mode=OneWay}"/><Run Text="%"/>
                                            </TextBlock>
                                        </DockPanel>
                                        <TextBlock Text="{Binding Display}"
                                                   Foreground="{StaticResource MutedBrush}" FontSize="11"/>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

            <!-- Equipos descubiertos -->
            <Border Grid.Column="1" Style="{StaticResource Card}">
                <StackPanel>
                    <TextBlock Text="Computadoras descubiertas en la red"
                               FontSize="16" FontWeight="SemiBold" Margin="0,0,0,4"/>
                    <TextBlock Text="Servidores, workstations y Raspberry Pi detectados por el escaneo. El detalle remoto (CPU/RAM/servicios) llegará con WMI remoto."
                               Foreground="{StaticResource MutedBrush}" FontSize="11"
                               TextWrapping="Wrap" Margin="0,0,0,10"/>
                    <DataGrid ItemsSource="{Binding Computers}"
                              AutoGenerateColumns="False" IsReadOnly="True"
                              Height="500">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="IP" Binding="{Binding IpAddress}" Width="120"/>
                            <DataGridTextColumn Header="Nombre / Host" Binding="{Binding Name}" Width="220"/>
                            <DataGridTextColumn Header="Tipo" Binding="{Binding TypeText}" Width="120"/>
                            <DataGridTextColumn Header="MAC" Binding="{Binding MacAddress}" Width="150"/>
                            <DataGridTextColumn Header="Fabricante" Binding="{Binding Vendor}" Width="120"/>
                            <DataGridTextColumn Header="Puertos" Binding="{Binding PortsText}" Width="150"/>
                            <DataGridTextColumn Header="Estado" Binding="{Binding StateText}" Width="100"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </StackPanel>
            </Border>
        </Grid>
    </StackPanel>
</UserControl>
