<UserControl x:Class="NetAdminStudio.Desktop.Views.EquiposView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:NetAdminStudio.Desktop.Controls"
             xmlns:b="clr-namespace:NetAdminStudio.Desktop.Behaviors">
    <StackPanel Margin="18">
        <DockPanel Margin="6,4,6,0" LastChildFill="False">
            <StackPanel DockPanel.Dock="Left">
                <TextBlock Text="Equipos" FontSize="26" FontWeight="SemiBold"/>
                <TextBlock Text="Detalle del equipo local y computadoras descubiertas"
                           Foreground="{StaticResource MutedBrush}"/>
            </StackPanel>
            <Button DockPanel.Dock="Right" Style="{StaticResource PrimaryButton}"
                    Content="↻  Actualizar" Command="{Binding RefreshCommand}"
                    VerticalAlignment="Center"/>
        </DockPanel>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="420"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Detalle del equipo (local o remoto seleccionado) -->
            <Border Grid.Column="0" Style="{StaticResource Card}">
                <StackPanel>
                    <DockPanel Margin="0,0,0,8">
                        <TextBlock Text="🖥️" FontSize="24" VerticalAlignment="Center"/>
                        <Button DockPanel.Dock="Right" Content="Este equipo"
                                Command="{Binding ShowLocalSystemCommand}"
                                VerticalAlignment="Center" FontSize="11" Padding="8,4"/>
                        <StackPanel Margin="10,0,0,0" VerticalAlignment="Center">
                            <TextBlock Text="{Binding SelectedSystem.MachineName}"
                                       FontSize="18" FontWeight="Bold"/>
                            <TextBlock Text="{Binding SelectedSystem.OperatingSystem}"
                                       Foreground="{StaticResource MutedBrush}" FontSize="12"/>
                        </StackPanel>
                    </DockPanel>

                    <TextBlock Text="{Binding SelectedSystem.CpuText}"
                               Foreground="{StaticResource MutedBrush}" FontSize="11"
                               TextWrapping="Wrap" Margin="0,0,0,10"/>

                    <UniformGrid Columns="3">
                        <controls:CircularGauge Label="CPU" Diameter="110"
                            Accent="{StaticResource AccentBrush}"
                            Percent="{Binding SelectedSystem.CpuUsagePercent, Mode=OneWay, FallbackValue=0, TargetNullValue=0}"/>
                        <controls:CircularGauge Label="Memoria" Diameter="110"
                            Accent="{StaticResource PurpleBrush}"
                            Percent="{Binding SelectedSystem.MemoryUsagePercent, Mode=OneWay, FallbackValue=0}"/>
                        <controls:CircularGauge Label="Disco C:" Diameter="110"
                            Accent="{StaticResource OrangeBrush}"
                            Percent="{Binding SelectedSystem.Disks[0].UsagePercent, Mode=OneWay, FallbackValue=0}"/>
                    </UniformGrid>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,6,0,10">
                        <TextBlock Text="{Binding SelectedSystem.MemoryText}"
                                   Foreground="{StaticResource MutedBrush}" FontSize="11"/>
                        <TextBlock Text="  ·  " Foreground="{StaticResource MutedBrush}" FontSize="11"/>
                        <TextBlock Text="{Binding SelectedSystem.ServicesText}"
                                   Foreground="{StaticResource MutedBrush}" FontSize="11"/>
                    </StackPanel>

                    <TextBlock Text="Discos" FontWeight="SemiBold" FontSize="13" Margin="0,4,0,6"/>
                    <ItemsControl ItemsSource="{Binding SelectedSystem.Disks}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="{StaticResource SurfaceAltBrush}"
                                        CornerRadius="8" Padding="10,8" Margin="0,0,0,6">
                                    <StackPanel>
                                        <DockPanel>
                                            <TextBlock Text="{Binding Drive}" DockPanel.Dock="Left" FontWeight="SemiBold"/>
                                            <TextBlock DockPanel.Dock="Right" HorizontalAlignment="Right"
                                                       Foreground="{StaticResource MutedBrush}" FontSize="11">
                                                <Run Text="{Binding UsagePercent, Mode=OneWay}"/><Run Text="%"/>
                                            </TextBlock>
                                        </DockPanel>
                                        <TextBlock Text="{Binding Display}"
                                                   Foreground="{StaticResource MutedBrush}" FontSize="11"/>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

            <!-- Equipos descubiertos -->
            <Border Grid.Column="1" Style="{StaticResource Card}">
                <StackPanel>
                    <TextBlock Text="Computadoras descubiertas en la red"
                               FontSize="16" FontWeight="SemiBold" Margin="0,0,0,4"/>
                    <TextBlock Text="Elegí una computadora y consultá su detalle real (CPU/RAM/discos) por WMI remoto. Requiere usuario y contraseña de administrador de ese equipo, y que tenga WMI habilitado."
                               Foreground="{StaticResource MutedBrush}" FontSize="11"
                               TextWrapping="Wrap" Margin="0,0,0,8"/>

                    <Border Background="{StaticResource SurfaceAltBrush}" CornerRadius="8"
                            Padding="10" Margin="0,0,0,10">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="Usuario:" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                <TextBox Width="150" VerticalContentAlignment="Center"
                                         Text="{Binding RemoteUser, UpdateSourceTrigger=PropertyChanged}"/>
                                <TextBlock Text="Contraseña:" VerticalAlignment="Center" Margin="12,0,6,0"/>
                                <PasswordBox x:Name="RemotePasswordBox" Width="150"
                                             Background="{StaticResource SurfaceBrush}"
                                             Foreground="{StaticResource TextBrush}"
                                             VerticalContentAlignment="Center" Padding="6,4"/>
                                <Button Content="💾  Guardar" Margin="8,0,0,0" Click="SaveCredential_Click"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                <Button Content="🔍  Ver detalle del equipo seleccionado"
                                        Style="{StaticResource PrimaryButton}" Click="LoadRemote_Click"/>
                                <TextBlock Text="Guardá una vez la credencial y después solo seleccioná el equipo."
                                           Foreground="{StaticResource MutedBrush}" FontSize="11"
                                           VerticalAlignment="Center" Margin="12,0,0,0"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <TextBlock Text="{Binding RemoteStatusText}" Foreground="{StaticResource AccentBrush}"
                               FontSize="11" TextWrapping="Wrap" Margin="2,0,0,8"/>

                    <DataGrid ItemsSource="{Binding Computers}"
                              SelectedItem="{Binding SelectedComputer, Mode=TwoWay}"
                              AutoGenerateColumns="False" IsReadOnly="True"
                              b:RowDetail.Enabled="True" Height="430">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="IP" Binding="{Binding IpAddress}" Width="120"/>
                            <DataGridTextColumn Header="Nombre / Host" Binding="{Binding Name}" Width="220"/>
                            <DataGridTextColumn Header="Tipo" Binding="{Binding TypeText}" Width="120"/>
                            <DataGridTextColumn Header="MAC" Binding="{Binding MacAddress}" Width="150"/>
                            <DataGridTextColumn Header="Fabricante" Binding="{Binding Vendor}" Width="120"/>
                            <DataGridTextColumn Header="Puertos" Binding="{Binding PortsText}" Width="150"/>
                            <DataGridTextColumn Header="Estado" Binding="{Binding StateText}" Width="100"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </StackPanel>
            </Border>
        </Grid>
    </StackPanel>
</UserControl>
