<UserControl x:Class="NetAdminStudio.Desktop.Views.UsuariosView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:b="clr-namespace:NetAdminStudio.Desktop.Behaviors">
    <StackPanel Margin="18">
        <DockPanel Margin="6,4,6,0" LastChildFill="False">
            <StackPanel DockPanel.Dock="Left">
                <TextBlock Text="Usuarios" FontSize="26" FontWeight="SemiBold"/>
                <TextBlock Text="Cuentas de usuario locales del equipo"
                           Foreground="{StaticResource MutedBrush}"/>
            </StackPanel>
            <Button DockPanel.Dock="Right" Content="↻  Actualizar"
                    Command="{Binding RefreshCommand}" VerticalAlignment="Center"/>
        </DockPanel>

        <Border Style="{StaticResource Card}">
            <StackPanel>
                <DockPanel Margin="0,0,0,10">
                    <TextBlock Text="Cuentas locales" FontSize="16" FontWeight="SemiBold" VerticalAlignment="Center"/>
                    <TextBlock DockPanel.Dock="Right" HorizontalAlignment="Right"
                               Foreground="{StaticResource MutedBrush}" VerticalAlignment="Center">
                        <Run Text="{Binding Users.Count, Mode=OneWay}"/><Run Text=" usuarios"/>
                    </TextBlock>
                </DockPanel>
                <DataGrid ItemsSource="{Binding Users}"
                          AutoGenerateColumns="False" IsReadOnly="True"
                          b:RowDetail.Enabled="True" Height="560">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Usuario" Binding="{Binding Name}" Width="180"/>
                        <DataGridTextColumn Header="Nombre completo" Binding="{Binding FullName}" Width="220"/>
                        <DataGridTextColumn Header="Estado" Binding="{Binding StateText}" Width="130"/>
                        <DataGridTextColumn Header="Descripción" Binding="{Binding Description}" Width="*"/>
                    </DataGrid.Columns>
                </DataGrid>
            </StackPanel>
        </Border>
    </StackPanel>
</UserControl>
