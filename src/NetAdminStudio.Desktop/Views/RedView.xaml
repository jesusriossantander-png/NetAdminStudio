<UserControl x:Class="NetAdminStudio.Desktop.Views.RedView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:b="clr-namespace:NetAdminStudio.Desktop.Behaviors">
    <StackPanel Margin="18">
        <DockPanel Margin="6,4,6,0" LastChildFill="False">
            <StackPanel DockPanel.Dock="Left">
                <TextBlock Text="Red" FontSize="26" FontWeight="SemiBold"/>
                <TextBlock Text="Descubrimiento y estado de los dispositivos de red"
                           Foreground="{StaticResource MutedBrush}"/>
            </StackPanel>
            <Button DockPanel.Dock="Right" Style="{StaticResource PrimaryButton}"
                    Content="↻  Actualizar" Command="{Binding RefreshCommand}"
                    VerticalAlignment="Center"/>
        </DockPanel>

        <Border Style="{StaticResource Card}">
            <StackPanel>
                <TextBlock Text="Escaneo de red" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,10"/>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Rango (CIDR):" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <TextBox Width="180" VerticalContentAlignment="Center"
                             Text="{Binding ScanCidr, UpdateSourceTrigger=PropertyChanged}"
                             IsEnabled="{Binding CanScan}"/>
                    <Button Style="{StaticResource PrimaryButton}" Content="🔍  Escanear red"
                            Margin="10,0,0,0" Command="{Binding ScanCommand}"
                            IsEnabled="{Binding CanScan}"/>
                    <TextBlock Text="{Binding ScanStatusText}" VerticalAlignment="Center"
                               Foreground="{StaticResource MutedBrush}" Margin="16,0,0,0"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <Border Style="{StaticResource Card}">
            <StackPanel>
                <TextBlock Text="Activos de red" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,10"/>
                <DataGrid ItemsSource="{Binding Assets}"
                          AutoGenerateColumns="False" IsReadOnly="True"
                          b:RowDetail.Enabled="True" Height="520">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="IP" Binding="{Binding IpAddress}" Width="120"/>
                        <DataGridTextColumn Header="Nombre / Host" Binding="{Binding Name}" Width="220"/>
                        <DataGridTextColumn Header="MAC" Binding="{Binding MacAddress}" Width="150"/>
                        <DataGridTextColumn Header="Fabricante" Binding="{Binding Vendor}" Width="130"/>
                        <DataGridTextColumn Header="Tipo" Binding="{Binding TypeText}" Width="130"/>
                        <DataGridTextColumn Header="Puertos" Binding="{Binding PortsText}" Width="180"/>
                        <DataGridTextColumn Header="Estado" Binding="{Binding StateText}" Width="110"/>
                        <DataGridTextColumn Header="Latencia" Binding="{Binding LatencyMs}" Width="90"/>
                    </DataGrid.Columns>
                </DataGrid>
            </StackPanel>
        </Border>
    </StackPanel>
</UserControl>
