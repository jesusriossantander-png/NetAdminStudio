<UserControl x:Class="NetAdminStudio.Desktop.Views.ImpresorasView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <StackPanel Margin="18">
        <DockPanel Margin="6,4,6,0">
            <StackPanel DockPanel.Dock="Left">
                <TextBlock Text="Impresoras" FontSize="26" FontWeight="SemiBold"/>
                <TextBlock Text="Impresoras detectadas en el equipo y la red"
                           Foreground="{StaticResource MutedBrush}"/>
            </StackPanel>
            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="{Binding PrinterStatusText}" VerticalAlignment="Center"
                           Foreground="{StaticResource MutedBrush}" Margin="0,0,12,0"/>
                <Button Style="{StaticResource PrimaryButton}" Content="🖨️  Detectar impresoras"
                        Command="{Binding ScanPrintersCommand}"/>
            </StackPanel>
        </DockPanel>

        <Border Style="{StaticResource Card}">
            <StackPanel>
                <TextBlock Text="Listado de impresoras" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,10"/>
                <DataGrid ItemsSource="{Binding Printers}"
                          AutoGenerateColumns="False" IsReadOnly="True"
                          Height="540">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Nombre" Binding="{Binding Name}" Width="240"/>
                        <DataGridTextColumn Header="Conexión" Binding="{Binding ConnectionType}" Width="160"/>
                        <DataGridTextColumn Header="Modelo" Binding="{Binding Model}" Width="220"/>
                        <DataGridTextColumn Header="Tóner %" Binding="{Binding BlackLevelPercent}" Width="90"/>
                        <DataGridTextColumn Header="Cola" Binding="{Binding PendingJobs}" Width="80"/>
                    </DataGrid.Columns>
                </DataGrid>
            </StackPanel>
        </Border>
    </StackPanel>
</UserControl>
