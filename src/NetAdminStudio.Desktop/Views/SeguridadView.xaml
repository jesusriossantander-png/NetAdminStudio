<UserControl x:Class="NetAdminStudio.Desktop.Views.SeguridadView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:b="clr-namespace:NetAdminStudio.Desktop.Behaviors">
    <StackPanel Margin="18">
        <DockPanel Margin="6,4,6,0" LastChildFill="False">
            <StackPanel DockPanel.Dock="Left">
                <TextBlock Text="Seguridad" FontSize="26" FontWeight="SemiBold"/>
                <TextBlock Text="Quién tiene acceso a cada carpeta compartida (permisos NTFS)"
                           Foreground="{StaticResource MutedBrush}"/>
            </StackPanel>
            <Button DockPanel.Dock="Right" Content="↻  Actualizar"
                    Command="{Binding RefreshCommand}" VerticalAlignment="Center"/>
        </DockPanel>

        <Border Style="{StaticResource Card}">
            <StackPanel>
                <DockPanel Margin="0,0,0,10">
                    <TextBlock Text="Permisos de carpetas compartidas" FontSize="16"
                               FontWeight="SemiBold" VerticalAlignment="Center"/>
                    <TextBlock DockPanel.Dock="Right" HorizontalAlignment="Right"
                               Foreground="{StaticResource MutedBrush}" VerticalAlignment="Center">
                        <Run Text="{Binding Permissions.Count, Mode=OneWay}"/><Run Text=" permisos"/>
                    </TextBlock>
                </DockPanel>
                <DataGrid ItemsSource="{Binding Permissions}"
                          AutoGenerateColumns="False" IsReadOnly="True"
                          b:RowDetail.Enabled="True" Height="560">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Recurso" Binding="{Binding Share}" Width="150"/>
                        <DataGridTextColumn Header="Ruta" Binding="{Binding Path}" Width="220"/>
                        <DataGridTextColumn Header="Identidad" Binding="{Binding Identity}" Width="240"/>
                        <DataGridTextColumn Header="Permiso" Binding="{Binding Rights}" Width="160"/>
                        <DataGridTextColumn Header="Acceso" Binding="{Binding Access}" Width="100"/>
                    </DataGrid.Columns>
                </DataGrid>
            </StackPanel>
        </Border>
    </StackPanel>
</UserControl>
