<Window x:Class="NetAdminStudio.Desktop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="NetAdmin Studio"
        Width="1450"
        Height="900"
        WindowStartupLocation="CenterScreen">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="230"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ===== SIDEBAR ===== -->
        <Border Background="{StaticResource SidebarBrush}" BorderBrush="{StaticResource BorderBrushColor}" BorderThickness="0,0,1,0">
            <DockPanel Margin="14">
                <StackPanel DockPanel.Dock="Top">
                    <StackPanel Orientation="Horizontal" Margin="4,4,0,10">
                        <TextBlock Text="🛡️" FontSize="22" VerticalAlignment="Center"/>
                        <StackPanel Margin="8,0,0,0" VerticalAlignment="Center">
                            <TextBlock Text="NetAdmin" FontSize="17" FontWeight="Bold"/>
                            <TextBlock Text="Studio Enterprise" FontSize="10" Foreground="{StaticResource AccentBrush}"/>
                        </StackPanel>
                    </StackPanel>
                    <Border Height="1" Background="{StaticResource BorderBrushColor}" Margin="0,4,0,8"/>

                    <Button Style="{StaticResource NavButtonActive}" Content="📊   Centro de operaciones"/>
                    <Button Style="{StaticResource NavButton}" Content="🌐   Red"/>
                    <Button Style="{StaticResource NavButton}" Content="🖥️   Equipos"/>
                    <Button Style="{StaticResource NavButton}" Content="🖨️   Impresoras"/>
                    <Button Style="{StaticResource NavButton}" Content="📁   Carpetas"/>
                    <Button Style="{StaticResource NavButton}" Content="👤   Usuarios"/>
                    <Button Style="{StaticResource NavButton}" Content="👥   Grupos"/>
                    <Button Style="{StaticResource NavButton}" Content="🔒   Seguridad"/>
                    <Button Style="{StaticResource NavButton}" Content="📦   Inventario"/>
                    <Button Style="{StaticResource NavButton}" Content="🔔   Alertas"/>
                    <Button Style="{StaticResource NavButton}" Content="📋   Auditoría"/>
                    <Button Style="{StaticResource NavButton}" Content="📄   Informes"/>
                    <Button Style="{StaticResource NavButton}" Content="🤖   Automatizaciones"/>
                    <Button Style="{StaticResource NavButton}" Content="⚙️   Configuración"/>
                </StackPanel>

                <Border DockPanel.Dock="Bottom" Style="{StaticResource Card}" Margin="0,8,0,0" Padding="10">
                    <StackPanel>
                        <TextBlock Text="Fernando" FontWeight="SemiBold" FontSize="13"/>
                        <TextBlock Text="Administrador" Foreground="{StaticResource MutedBrush}" FontSize="11"/>
                        <TextBlock Text="{Binding Status}" Foreground="{StaticResource MutedBrush}"
                                   FontSize="10" TextWrapping="Wrap" Margin="0,6,0,0"/>
                    </StackPanel>
                </Border>
            </DockPanel>
        </Border>

        <!-- ===== CONTENIDO ===== -->
        <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="18">
                <!-- Cabecera -->
                <DockPanel Margin="6,4,6,0">
                    <StackPanel DockPanel.Dock="Left">
                        <TextBlock Text="Centro de Operaciones" FontSize="26" FontWeight="SemiBold"/>
                        <TextBlock Text="Estado general de la infraestructura"
                                   Foreground="{StaticResource MutedBrush}"/>
                    </StackPanel>
                    <Button DockPanel.Dock="Right" Style="{StaticResource PrimaryButton}"
                            Content="↻  Actualizar" Command="{Binding RefreshCommand}"
                            VerticalAlignment="Center"/>
                </DockPanel>

                <!-- KPIs -->
                <UniformGrid Columns="6" Margin="0,14,0,4">
                    <Border Style="{StaticResource Card}" Background="{StaticResource GreenBrush}" BorderThickness="0">
                        <StackPanel>
                            <TextBlock Text="🖥️" FontSize="20"/>
                            <TextBlock Text="{Binding Dashboard.Online}" FontSize="30" FontWeight="Bold" Margin="0,4,0,0"/>
                            <TextBlock Text="Equipos online" Foreground="#DCFCE7" FontSize="12"/>
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource Card}" Background="{StaticResource RedBrush}" BorderThickness="0">
                        <StackPanel>
                            <TextBlock Text="⚠️" FontSize="20"/>
                            <TextBlock Text="{Binding Dashboard.Offline}" FontSize="30" FontWeight="Bold" Margin="0,4,0,0"/>
                            <TextBlock Text="Equipos offline" Foreground="#FEE2E2" FontSize="12"/>
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource Card}" Background="{StaticResource OrangeBrush}" BorderThickness="0">
                        <StackPanel>
                            <TextBlock Text="🔔" FontSize="20"/>
                            <TextBlock Text="{Binding Dashboard.OpenAlerts}" FontSize="30" FontWeight="Bold" Margin="0,4,0,0"/>
                            <TextBlock Text="Alertas activas" Foreground="#FEF3C7" FontSize="12"/>
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource Card}" Background="{StaticResource PurpleBrush}" BorderThickness="0">
                        <StackPanel>
                            <TextBlock Text="🖨️" FontSize="20"/>
                            <TextBlock Text="{Binding Dashboard.Printers}" FontSize="30" FontWeight="Bold" Margin="0,4,0,0"/>
                            <TextBlock Text="Impresoras" Foreground="#EDE9FE" FontSize="12"/>
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource Card}" Background="{StaticResource BlueBrush}" BorderThickness="0">
                        <StackPanel>
                            <TextBlock Text="📦" FontSize="20"/>
                            <TextBlock Text="{Binding Dashboard.Assets}" FontSize="30" FontWeight="Bold" Margin="0,4,0,0"/>
                            <TextBlock Text="Activos totales" Foreground="#DBEAFE" FontSize="12"/>
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource Card}" Background="{StaticResource CyanBrush}" BorderThickness="0">
                        <StackPanel>
                            <TextBlock Text="📉" FontSize="20"/>
                            <TextBlock Text="{Binding Dashboard.Degraded}" FontSize="30" FontWeight="Bold" Margin="0,4,0,0"/>
                            <TextBlock Text="Degradados" Foreground="#CFFAFE" FontSize="12"/>
                        </StackPanel>
                    </Border>
                </UniformGrid>

                <!-- Escaneo de red -->
                <Border Style="{StaticResource Card}">
                    <StackPanel>
                        <TextBlock Text="Escaneo de red" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,10"/>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Rango (CIDR):" VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <TextBox Width="180" VerticalContentAlignment="Center"
                                     Text="{Binding ScanCidr, UpdateSourceTrigger=PropertyChanged}"
                                     IsEnabled="{Binding CanScan}"/>
                            <Button Style="{StaticResource PrimaryButton}" Content="🔍  Escanear red"
                                    Margin="10,0,0,0" Command="{Binding ScanCommand}"
                                    IsEnabled="{Binding CanScan}"/>
                            <TextBlock Text="{Binding ScanStatusText}" VerticalAlignment="Center"
                                       Foreground="{StaticResource MutedBrush}" Margin="16,0,0,0"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel>
                        <Border Style="{StaticResource Card}">
                            <StackPanel>
                                <TextBlock Text="Activos de red" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,10"/>
                                <DataGrid ItemsSource="{Binding Assets}"
                                          AutoGenerateColumns="False" IsReadOnly="True"
                                          Height="320">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="IP" Binding="{Binding IpAddress}" Width="120"/>
                                        <DataGridTextColumn Header="Nombre / Host" Binding="{Binding Name}" Width="200"/>
                                        <DataGridTextColumn Header="MAC" Binding="{Binding MacAddress}" Width="150"/>
                                        <DataGridTextColumn Header="Fabricante" Binding="{Binding Vendor}" Width="120"/>
                                        <DataGridTextColumn Header="Tipo" Binding="{Binding TypeText}" Width="120"/>
                                        <DataGridTextColumn Header="Puertos" Binding="{Binding PortsText}" Width="160"/>
                                        <DataGridTextColumn Header="Estado" Binding="{Binding StateText}" Width="100"/>
                                        <DataGridTextColumn Header="Latencia" Binding="{Binding LatencyMs}" Width="90"/>
                                    </DataGrid.Columns>
                                </DataGrid>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource Card}">
                            <StackPanel>
                                <DockPanel Margin="0,0,0,10">
                                    <TextBlock DockPanel.Dock="Left" Text="Impresoras"
                                               FontSize="16" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                    <Button DockPanel.Dock="Right" Style="{StaticResource PrimaryButton}"
                                            Content="🖨️  Detectar impresoras"
                                            Command="{Binding ScanPrintersCommand}"
                                            HorizontalAlignment="Right"/>
                                    <TextBlock Text="{Binding PrinterStatusText}" VerticalAlignment="Center"
                                               HorizontalAlignment="Right" Margin="0,0,12,0"
                                               Foreground="{StaticResource MutedBrush}"/>
                                </DockPanel>
                                <DataGrid ItemsSource="{Binding Printers}"
                                          AutoGenerateColumns="False" IsReadOnly="True"
                                          Height="200">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Nombre" Binding="{Binding Name}" Width="180"/>
                                        <DataGridTextColumn Header="Conexión" Binding="{Binding ConnectionType}" Width="150"/>
                                        <DataGridTextColumn Header="Modelo" Binding="{Binding Model}" Width="150"/>
                                        <DataGridTextColumn Header="Tóner %" Binding="{Binding BlackLevelPercent}" Width="90"/>
                                        <DataGridTextColumn Header="Cola" Binding="{Binding PendingJobs}" Width="80"/>
                                    </DataGrid.Columns>
                                </DataGrid>
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <StackPanel Grid.Column="1">
                        <Border Style="{StaticResource Card}">
                            <StackPanel>
                                <TextBlock Text="Alertas abiertas" FontSize="16" FontWeight="SemiBold"/>
                                <ItemsControl ItemsSource="{Binding Alerts}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Background="{StaticResource SurfaceAltBrush}"
                                                    CornerRadius="8" Padding="10" Margin="0,8,0,0">
                                                <StackPanel>
                                                    <TextBlock Text="{Binding Title}" TextWrapping="Wrap"/>
                                                    <TextBlock Text="{Binding OpenedAt}"
                                                               Foreground="{StaticResource MutedBrush}" FontSize="11"/>
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource Card}">
                            <StackPanel>
                                <TextBlock Text="Asistente de operaciones" FontSize="16" FontWeight="SemiBold"/>
                                <TextBox Text="{Binding AssistantQuestion, UpdateSourceTrigger=PropertyChanged}"
                                         Margin="0,10,0,6"/>
                                <Button Style="{StaticResource PrimaryButton}" Content="Preguntar"
                                        Command="{Binding AskAssistantCommand}" HorizontalAlignment="Left"/>
                                <TextBlock Text="{Binding AssistantAnswer}" TextWrapping="Wrap" Margin="0,10,0,0"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Grid>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Window>
