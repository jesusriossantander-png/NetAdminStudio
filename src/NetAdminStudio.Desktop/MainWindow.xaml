<Window x:Class="NetAdminStudio.Desktop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:NetAdminStudio.Desktop.Views"
        Title="NetAdmin Studio"
        Width="1450"
        Height="900"
        WindowStartupLocation="CenterScreen">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="230"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ===== SIDEBAR ===== -->
        <Border Background="{StaticResource SidebarBrush}" BorderBrush="{StaticResource BorderBrushColor}" BorderThickness="0,0,1,0">
            <DockPanel Margin="14">
                <StackPanel DockPanel.Dock="Top">
                    <StackPanel Orientation="Horizontal" Margin="4,4,0,10">
                        <TextBlock Text="🛡️" FontSize="22" VerticalAlignment="Center"/>
                        <StackPanel Margin="8,0,0,0" VerticalAlignment="Center">
                            <TextBlock Text="NetAdmin" FontSize="17" FontWeight="Bold"/>
                            <TextBlock Text="Studio Enterprise" FontSize="10" Foreground="{StaticResource AccentBrush}"/>
                        </StackPanel>
                    </StackPanel>
                    <Border Height="1" Background="{StaticResource BorderBrushColor}" Margin="0,4,0,8"/>

                    <Button Content="📊   Centro de operaciones"
                            Command="{Binding NavigateCommand}" CommandParameter="dashboard"
                            Style="{Binding SelectedSection, Converter={StaticResource SectionToNavStyle}, ConverterParameter=dashboard}"/>
                    <Button Content="🌐   Red"
                            Command="{Binding NavigateCommand}" CommandParameter="red"
                            Style="{Binding SelectedSection, Converter={StaticResource SectionToNavStyle}, ConverterParameter=red}"/>
                    <Button Content="🖨️   Impresoras"
                            Command="{Binding NavigateCommand}" CommandParameter="impresoras"
                            Style="{Binding SelectedSection, Converter={StaticResource SectionToNavStyle}, ConverterParameter=impresoras}"/>
                    <Button Content="🖥️   Equipos"
                            Command="{Binding NavigateCommand}" CommandParameter="equipos"
                            Style="{Binding SelectedSection, Converter={StaticResource SectionToNavStyle}, ConverterParameter=equipos}"/>
                    <Button Content="📁   Carpetas"
                            Command="{Binding NavigateCommand}" CommandParameter="carpetas"
                            Style="{Binding SelectedSection, Converter={StaticResource SectionToNavStyle}, ConverterParameter=carpetas}"/>
                    <Button Content="👤   Usuarios"
                            Command="{Binding NavigateCommand}" CommandParameter="usuarios"
                            Style="{Binding SelectedSection, Converter={StaticResource SectionToNavStyle}, ConverterParameter=usuarios}"/>
                    <Button Content="👥   Grupos"
                            Command="{Binding NavigateCommand}" CommandParameter="grupos"
                            Style="{Binding SelectedSection, Converter={StaticResource SectionToNavStyle}, ConverterParameter=grupos}"/>
                    <Button Style="{StaticResource NavButton}" Content="🔒   Seguridad"/>
                    <Button Content="📦   Inventario"
                            Command="{Binding NavigateCommand}" CommandParameter="inventario"
                            Style="{Binding SelectedSection, Converter={StaticResource SectionToNavStyle}, ConverterParameter=inventario}"/>
                    <Button Content="🔔   Alertas"
                            Command="{Binding NavigateCommand}" CommandParameter="alertas"
                            Style="{Binding SelectedSection, Converter={StaticResource SectionToNavStyle}, ConverterParameter=alertas}"/>
                    <Button Style="{StaticResource NavButton}" Content="📋   Auditoría"/>
                    <Button Style="{StaticResource NavButton}" Content="📄   Informes"/>
                    <Button Content="🤖   Automatizaciones"
                            Command="{Binding NavigateCommand}" CommandParameter="automatizaciones"
                            Style="{Binding SelectedSection, Converter={StaticResource SectionToNavStyle}, ConverterParameter=automatizaciones}"/>
                    <Button Content="⚙️   Configuración"
                            Command="{Binding NavigateCommand}" CommandParameter="configuracion"
                            Style="{Binding SelectedSection, Converter={StaticResource SectionToNavStyle}, ConverterParameter=configuracion}"/>
                </StackPanel>

                <Border DockPanel.Dock="Bottom" Style="{StaticResource Card}" Margin="0,8,0,0" Padding="10">
                    <StackPanel>
                        <TextBlock Text="Fernando" FontWeight="SemiBold" FontSize="13"/>
                        <TextBlock Text="Administrador" Foreground="{StaticResource MutedBrush}" FontSize="11"/>
                        <TextBlock Text="{Binding Status}" Foreground="{StaticResource MutedBrush}"
                                   FontSize="10" TextWrapping="Wrap" Margin="0,6,0,0"/>
                    </StackPanel>
                </Border>
            </DockPanel>
        </Border>

        <!-- ===== CONTENIDO (vista según sección) ===== -->
        <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto">
            <Grid>
                <views:DashboardView
                    Visibility="{Binding SelectedSection, Converter={StaticResource SectionToVisibility}, ConverterParameter=dashboard}"/>
                <views:RedView
                    Visibility="{Binding SelectedSection, Converter={StaticResource SectionToVisibility}, ConverterParameter=red}"/>
                <views:ImpresorasView
                    Visibility="{Binding SelectedSection, Converter={StaticResource SectionToVisibility}, ConverterParameter=impresoras}"/>
                <views:EquiposView
                    Visibility="{Binding SelectedSection, Converter={StaticResource SectionToVisibility}, ConverterParameter=equipos}"/>
                <views:AlertasView
                    Visibility="{Binding SelectedSection, Converter={StaticResource SectionToVisibility}, ConverterParameter=alertas}"/>
                <views:InventarioView
                    Visibility="{Binding SelectedSection, Converter={StaticResource SectionToVisibility}, ConverterParameter=inventario}"/>
                <views:AutomatizacionesView
                    Visibility="{Binding SelectedSection, Converter={StaticResource SectionToVisibility}, ConverterParameter=automatizaciones}"/>
                <views:ConfiguracionView
                    Visibility="{Binding SelectedSection, Converter={StaticResource SectionToVisibility}, ConverterParameter=configuracion}"/>
                <views:CarpetasView
                    Visibility="{Binding SelectedSection, Converter={StaticResource SectionToVisibility}, ConverterParameter=carpetas}"/>
                <views:UsuariosView
                    Visibility="{Binding SelectedSection, Converter={StaticResource SectionToVisibility}, ConverterParameter=usuarios}"/>
                <views:GruposView
                    Visibility="{Binding SelectedSection, Converter={StaticResource SectionToVisibility}, ConverterParameter=grupos}"/>
            </Grid>
        </ScrollViewer>
    </Grid>
</Window>
