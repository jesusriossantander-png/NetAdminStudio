<Window x:Class="NetAdminStudio.Desktop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="NetAdminStudio"
        Width="1450"
        Height="900"
        WindowStartupLocation="CenterScreen">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Background="#0F172A">
            <DockPanel Margin="16">
                <StackPanel DockPanel.Dock="Top">
                    <TextBlock Text="NETADMIN" FontSize="22" FontWeight="Bold"/>
                    <TextBlock Text="STUDIO" Foreground="{StaticResource AccentBrush}" FontSize="12"/>
                    <Separator Margin="0,18"/>
                    <Button Content="Centro de operaciones"/>
                    <Button Content="Red"/>
                    <Button Content="Impresoras"/>
                    <Button Content="Alertas"/>
                    <Button Content="Automatizaciones"/>
                    <Button Content="Asistente IA"/>
                    <Button Content="Configuración"/>
                </StackPanel>

                <TextBlock DockPanel.Dock="Bottom"
                           Text="{Binding Status}"
                           Foreground="{StaticResource MutedBrush}"
                           TextWrapping="Wrap"/>
            </DockPanel>
        </Border>

        <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="20">
                <DockPanel>
                    <StackPanel DockPanel.Dock="Left">
                        <TextBlock Text="Centro de Operaciones"
                                   FontSize="30"
                                   FontWeight="SemiBold"/>
                        <TextBlock Text="Estado general de la infraestructura"
                                   Foreground="{StaticResource MutedBrush}"/>
                    </StackPanel>

                    <Button DockPanel.Dock="Right"
                            Content="Actualizar"
                            Command="{Binding RefreshCommand}"/>
                </DockPanel>

                <Border Style="{StaticResource Card}" Margin="0,14,0,0">
                    <StackPanel>
                        <TextBlock Text="Escaneo de red"
                                   FontSize="18"
                                   FontWeight="SemiBold"
                                   Margin="0,0,0,10"/>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Rango (CIDR):"
                                       VerticalAlignment="Center"
                                       Margin="0,0,8,0"/>
                            <TextBox Width="180"
                                     Padding="6"
                                     VerticalContentAlignment="Center"
                                     Text="{Binding ScanCidr, UpdateSourceTrigger=PropertyChanged}"
                                     IsEnabled="{Binding CanScan}"/>
                            <Button Content="Escanear red"
                                    Margin="10,0,0,0"
                                    Command="{Binding ScanCommand}"
                                    IsEnabled="{Binding CanScan}"/>
                            <TextBlock Text="{Binding ScanStatusText}"
                                       VerticalAlignment="Center"
                                       Foreground="{StaticResource MutedBrush}"
                                       Margin="16,0,0,0"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <UniformGrid Columns="6" Margin="0,18,0,12">
                    <Border Style="{StaticResource Card}">
                        <StackPanel>
                            <TextBlock Text="Activos" Foreground="{StaticResource MutedBrush}"/>
                            <TextBlock Text="{Binding Dashboard.Assets}" FontSize="28"/>
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource Card}">
                        <StackPanel>
                            <TextBlock Text="Online" Foreground="{StaticResource MutedBrush}"/>
                            <TextBlock Text="{Binding Dashboard.Online}" FontSize="28"/>
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource Card}">
                        <StackPanel>
                            <TextBlock Text="Degradados" Foreground="{StaticResource MutedBrush}"/>
                            <TextBlock Text="{Binding Dashboard.Degraded}" FontSize="28"/>
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource Card}">
                        <StackPanel>
                            <TextBlock Text="Offline" Foreground="{StaticResource MutedBrush}"/>
                            <TextBlock Text="{Binding Dashboard.Offline}" FontSize="28"/>
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource Card}">
                        <StackPanel>
                            <TextBlock Text="Impresoras" Foreground="{StaticResource MutedBrush}"/>
                            <TextBlock Text="{Binding Dashboard.Printers}" FontSize="28"/>
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource Card}">
                        <StackPanel>
                            <TextBlock Text="Alertas" Foreground="{StaticResource MutedBrush}"/>
                            <TextBlock Text="{Binding Dashboard.OpenAlerts}" FontSize="28"/>
                        </StackPanel>
                    </Border>
                </UniformGrid>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel>
                        <Border Style="{StaticResource Card}">
                            <StackPanel>
                                <TextBlock Text="Activos de red"
                                           FontSize="18"
                                           FontWeight="SemiBold"
                                           Margin="0,0,0,10"/>
                                <DataGrid ItemsSource="{Binding Assets}"
                                          AutoGenerateColumns="False"
                                          IsReadOnly="True"
                                          Height="300">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="IP" Binding="{Binding IpAddress}" Width="120"/>
                                        <DataGridTextColumn Header="Nombre/Host" Binding="{Binding Name}" Width="*"/>
                                        <DataGridTextColumn Header="MAC" Binding="{Binding MacAddress}" Width="140"/>
                                        <DataGridTextColumn Header="Fabricante" Binding="{Binding Vendor}" Width="110"/>
                                        <DataGridTextColumn Header="Tipo" Binding="{Binding TypeText}" Width="100"/>
                                        <DataGridTextColumn Header="Puertos" Binding="{Binding PortsText}" Width="130"/>
                                        <DataGridTextColumn Header="Estado" Binding="{Binding StateText}" Width="90"/>
                                        <DataGridTextColumn Header="Latencia" Binding="{Binding LatencyMs}" Width="80"/>
                                    </DataGrid.Columns>
                                </DataGrid>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource Card}">
                            <StackPanel>
                                <TextBlock Text="Impresoras"
                                           FontSize="18"
                                           FontWeight="SemiBold"
                                           Margin="0,0,0,10"/>
                                <DataGrid ItemsSource="{Binding Printers}"
                                          AutoGenerateColumns="False"
                                          IsReadOnly="True"
                                          Height="220">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Nombre" Binding="{Binding Name}" Width="*"/>
                                        <DataGridTextColumn Header="Conexión" Binding="{Binding ConnectionType}" Width="150"/>
                                        <DataGridTextColumn Header="Modelo" Binding="{Binding Model}" Width="140"/>
                                        <DataGridTextColumn Header="Tóner" Binding="{Binding BlackLevelPercent}" Width="70"/>
                                        <DataGridTextColumn Header="Cola" Binding="{Binding PendingJobs}" Width="70"/>
                                    </DataGrid.Columns>
                                </DataGrid>
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <StackPanel Grid.Column="1">
                        <Border Style="{StaticResource Card}">
                            <StackPanel>
                                <TextBlock Text="Alertas abiertas"
                                           FontSize="18"
                                           FontWeight="SemiBold"/>
                                <ItemsControl ItemsSource="{Binding Alerts}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Background="{StaticResource SurfaceAltBrush}"
                                                    CornerRadius="6"
                                                    Padding="10"
                                                    Margin="0,8,0,0">
                                                <StackPanel>
                                                    <TextBlock Text="{Binding Title}" TextWrapping="Wrap"/>
                                                    <TextBlock Text="{Binding OpenedAt}"
                                                               Foreground="{StaticResource MutedBrush}"
                                                               FontSize="11"/>
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource Card}">
                            <StackPanel>
                                <TextBlock Text="Asistente de operaciones"
                                           FontSize="18"
                                           FontWeight="SemiBold"/>
                                <TextBox Text="{Binding AssistantQuestion, UpdateSourceTrigger=PropertyChanged}"
                                         Margin="0,10,0,4"
                                         Padding="8"/>
                                <Button Content="Preguntar"
                                        Command="{Binding AskAssistantCommand}"
                                        HorizontalAlignment="Left"/>
                                <TextBlock Text="{Binding AssistantAnswer}"
                                           TextWrapping="Wrap"
                                           Margin="0,10,0,0"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Grid>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Window>
